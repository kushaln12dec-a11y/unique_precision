generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String
  passwordText String?
  firstName    String?
  lastName     String?
  phone        String?
  empId        String?  @unique
  image        String?
  role         String   @default("OPERATOR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdJobs  Job[]    @relation("JobsCreated")
  assignedJobs Job[]    @relation("JobsAssigned")
  logs         EmployeeLog[]
}

model Job {
  id               String   @id @default(uuid()) @db.Uuid
  groupId          BigInt  @db.BigInt
  customer         String?
  rate             Decimal? @db.Decimal(12, 2)
  cut              Decimal? @db.Decimal(12, 4)
  thickness        Decimal? @db.Decimal(12, 4)
  passLevel        String?
  setting          String?
  qty              Int?
  sedm             String?  @default("No")
  sedmSelectionType String?
  sedmRangeKey     String?
  sedmStandardValue String?
  sedmLengthType   String?
  sedmOver20Length Decimal? @db.Decimal(12, 4)
  sedmLengthValue  Decimal? @db.Decimal(12, 4)
  sedmHoles        Int?
  sedmEntriesJson  String?
  operationRowsJson String?
  material         String?
  priority         String?
  description      String?
  remark           String?
  programRefFile   String?
  cutImage         String?
  critical         Boolean  @default(false)
  pipFinish        Boolean  @default(false)
  totalHrs         Decimal? @db.Decimal(12, 2)
  totalAmount      Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now())
  createdBy        String
  assignedTo       String?  @default("Unassigned")
  refNumber        String?
  startTime        String?
  endTime          String?
  machineHrs       String?
  machineNumber    String?
  opsName          String?
  idleTime         String?
  idleTimeDuration String?
  lastImage        String?
  qcDecision       String   @default("PENDING")
  qcReportClosed   Boolean  @default(false)
  updatedBy        String?
  updatedAt        DateTime?

  createdByUserId  String?  @db.Uuid
  assignedToUserId String?  @db.Uuid
  createdByUser    User?    @relation("JobsCreated", fields: [createdByUserId], references: [id])
  assignedToUser   User?    @relation("JobsAssigned", fields: [assignedToUserId], references: [id])

  operatorCaptures JobOperatorCapture[]
  qaStates         JobQuantityQaState[]
  logs             EmployeeLog[]

  @@index([groupId])
  @@index([createdAt])
  @@index([groupId, createdAt(sort: Desc)])
  @@index([customer])
  @@index([description])
  @@index([createdBy])
  @@index([assignedTo])
  @@index([priority])
  @@index([sedm])
  @@index([critical])
  @@index([pipFinish])
}

model JobOperatorCapture {
  id              String  @id @default(uuid()) @db.Uuid
  jobId           String  @db.Uuid
  captureMode     String
  fromQty         Int
  toQty           Int
  quantityCount   Int
  startTime       String?
  endTime         String?
  machineHrs      String?
  machineNumber   String?
  opsName         String?
  idleTime        String?
  idleTimeDuration String?
  lastImage       String?
  createdAt       String?
  createdBy       String?

  job             Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model JobQuantityQaState {
  jobId          String @db.Uuid
  quantityNumber Int
  status         String

  job            Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@id([jobId, quantityNumber])
  @@index([status])
}

model EmployeeLog {
  id             String   @id @default(uuid()) @db.Uuid
  role           String
  activityType   String
  status         String
  userId         String?  @db.Uuid
  userEmail      String?
  userName       String?
  jobId          String?  @db.Uuid
  jobGroupId     BigInt? @db.BigInt
  refNumber      String?
  settingLabel   String?
  quantityFrom   Int?
  quantityTo     Int?
  quantityCount  Int?
  jobCustomer    String?
  jobDescription String?
  workItemTitle  String?
  workSummary    String?
  startedAt      DateTime
  endedAt        DateTime?
  durationSeconds Int?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User?    @relation(fields: [userId], references: [id])
  job            Job?     @relation(fields: [jobId], references: [id])

  @@index([role])
  @@index([activityType])
  @@index([status])
  @@index([userId])
  @@index([userEmail])
  @@index([userName])
  @@index([jobGroupId])
  @@index([jobId])
  @@index([refNumber])
  @@index([quantityCount])
  @@index([jobCustomer])
  @@index([workItemTitle])
  @@index([startedAt])
  @@index([durationSeconds])
}

model MasterConfig {
  id                     String   @id @default(uuid()) @db.Uuid
  key                    String   @unique @default("global")
  settingHoursPerSetting Decimal? @db.Decimal(10, 2)
  thicknessRateUpto100   Decimal? @db.Decimal(12, 2)
  thicknessRateAbove100  Decimal? @db.Decimal(12, 2)
  complexExtraHours      Decimal? @db.Decimal(10, 2)
  pipExtraHours          Decimal? @db.Decimal(10, 2)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  customers              MasterConfigCustomer[]
  materials              MasterConfigMaterial[]
  passOptions            MasterConfigPassOption[]
  sedmElectrodeOptions   MasterConfigSedmElectrodeOption[]
  machineOptions         MasterConfigMachineOption[]
  sedmThOptions          MasterConfigSedmThOption[]
}

model MasterConfigCustomer {
  id             String       @id @default(uuid()) @db.Uuid
  masterConfigId String       @db.Uuid
  customer       String
  rate           Decimal?     @db.Decimal(12, 2)
  settingHours   Decimal?     @db.Decimal(10, 2)
  thicknessRateUpto100 Decimal? @db.Decimal(12, 2)
  thicknessRateAbove100 Decimal? @db.Decimal(12, 2)
  sedm034Min     Decimal?     @db.Decimal(12, 2)
  sedm034PerMm   Decimal?     @db.Decimal(12, 2)
  sedm056Min     Decimal?     @db.Decimal(12, 2)
  sedm056PerMm   Decimal?     @db.Decimal(12, 2)
  sedm07Min      Decimal?     @db.Decimal(12, 2)
  sedm07PerMm    Decimal?     @db.Decimal(12, 2)
  sedm0812Min    Decimal?     @db.Decimal(12, 2)
  sedm0812PerMm  Decimal?     @db.Decimal(12, 2)
  sedm1520Min    Decimal?     @db.Decimal(12, 2)
  sedm1520PerMm  Decimal?     @db.Decimal(12, 2)
  sedm2225Min    Decimal?     @db.Decimal(12, 2)
  sedm2225PerMm  Decimal?     @db.Decimal(12, 2)
  sedm30Min      Decimal?     @db.Decimal(12, 2)
  sedm30PerMm    Decimal?     @db.Decimal(12, 2)

  masterConfig   MasterConfig @relation(fields: [masterConfigId], references: [id], onDelete: Cascade)

  @@unique([masterConfigId, customer])
}

model MasterConfigMaterial {
  id             String       @id @default(uuid()) @db.Uuid
  masterConfigId String       @db.Uuid
  value          String

  masterConfig   MasterConfig @relation(fields: [masterConfigId], references: [id], onDelete: Cascade)

  @@unique([masterConfigId, value])
}

model MasterConfigPassOption {
  id             String       @id @default(uuid()) @db.Uuid
  masterConfigId String       @db.Uuid
  value          String

  masterConfig   MasterConfig @relation(fields: [masterConfigId], references: [id], onDelete: Cascade)

  @@unique([masterConfigId, value])
}

model MasterConfigSedmElectrodeOption {
  id             String       @id @default(uuid()) @db.Uuid
  masterConfigId String       @db.Uuid
  value          String

  masterConfig   MasterConfig @relation(fields: [masterConfigId], references: [id], onDelete: Cascade)

  @@unique([masterConfigId, value])
}

model MasterConfigMachineOption {
  id             String       @id @default(uuid()) @db.Uuid
  masterConfigId String       @db.Uuid
  value          String

  masterConfig   MasterConfig @relation(fields: [masterConfigId], references: [id], onDelete: Cascade)

  @@unique([masterConfigId, value])
}

model MasterConfigSedmThOption {
  id             String       @id @default(uuid()) @db.Uuid
  masterConfigId String       @db.Uuid
  value          String
  label          String

  masterConfig   MasterConfig @relation(fields: [masterConfigId], references: [id], onDelete: Cascade)

  @@unique([masterConfigId, value])
}

model IdleTimeConfig {
  id              String   @id @default(uuid()) @db.Uuid
  idleTimeType    String   @unique
  durationMinutes Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Counter {
  id        String @id @default(uuid()) @db.Uuid
  key       String @unique
  seq       Int    @default(0)
}
